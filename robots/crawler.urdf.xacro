<?xml version="1.0"?>
<robot name="crawler" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ==================== PROPERTIES ==================== -->
  <xacro:property name="chassis_length" value="0.4"/>
  <xacro:property name="chassis_width"  value="0.3"/>
  <xacro:property name="chassis_height" value="0.12"/>
  <xacro:property name="chassis_mass"   value="3.0"/>

  <xacro:property name="wheel_radius"   value="0.06"/>
  <xacro:property name="wheel_width"    value="0.04"/>
  <xacro:property name="wheel_mass"     value="0.4"/>

  <!-- ==================== BASE LINK ==================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="${chassis_mass}"/>
      <inertia ixx="0.0146" ixy="0" ixz="0"
               iyy="0.0206" iyz="0"
               izz="0.0316"/>
    </inertial>
  </link>

  <!-- ==================== WHEEL MACRO ==================== -->
  <xacro:macro name="wheel" params="name x_pos y_pos">

    <link name="${name}_wheel">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black">
          <color rgba="0.05 0.05 0.05 1.0"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia ixx="0.0006" ixy="0" ixz="0"
                 iyy="0.0006" iyz="0"
                 izz="0.0012"/>
      </inertial>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}_wheel"/>
      <origin xyz="${x_pos} ${y_pos} -0.04" rpy="-1.5708 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>

  </xacro:macro>

  <!-- Spawn 4 wheels -->
  <xacro:wheel name="front_left"  x_pos=" 0.14" y_pos=" 0.17"/>
  <xacro:wheel name="front_right" x_pos=" 0.14" y_pos="-0.17"/>
  <xacro:wheel name="rear_left"   x_pos="-0.14" y_pos=" 0.17"/>
  <xacro:wheel name="rear_right"  x_pos="-0.14" y_pos="-0.17"/>

  <!-- ==================== LIDAR ==================== -->
  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="0.04" length="0.06"/></geometry>
      <material name="lidar_color">
        <color rgba="0.0 0.5 1.0 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <origin xyz="0.1 0 0.09" rpy="0 0 0"/>
  </joint>

  <!-- ==================== THERMAL CAMERA ==================== -->
  <link name="thermal_cam_link">
    <visual>
      <geometry><box size="0.03 0.03 0.03"/></geometry>
      <material name="sensor_color">
        <color rgba="1.0 0.4 0.0 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="thermal_cam_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="thermal_cam_link"/>
    <origin xyz="0.2 0 0.04" rpy="0 0 0"/>
  </joint>

  <!-- ==================== MICROPHONE ARRAY ==================== -->
  <link name="mic_array_link">
    <visual>
      <geometry><sphere radius="0.02"/></geometry>
      <material name="mic_color">
        <color rgba="0.8 0.8 0.0 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="mic_array_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="mic_array_link"/>
    <origin xyz="0.0 0 0.1" rpy="0 0 0"/>
  </joint>

  <!-- ==================== ROS2 CONTROL PLUGIN ==================== -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <left_joint>front_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <wheel_separation>0.34</wheel_separation>
      <wheel_diameter>0.12</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
    </plugin>
  </gazebo>

  <!-- LiDAR Plugin -->
  <gazebo reference="lidar_link">
    <sensor name="lidar" type="ray">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
        </range>
      </ray>
      <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros><topic>scan</topic></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
      </plugin>
    </sensor>
  </gazebo>

</robot>
